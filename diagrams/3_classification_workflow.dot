digraph classification {
  rankdir=TB;
  graph [fontname="Helvetica", label="Track B — Seagrass Classification Workflow", labelloc=t, fontsize=15, fontcolor="#111111", bgcolor="white", nodesep=0.35, ranksep=0.45, pad=0.3];
  node  [shape=box, style="rounded,filled", fillcolor="white", color="#222222", penwidth=1.1, fontname="Helvetica", fontsize=11, fontcolor="#111111", margin="0.16,0.10"];
  edge  [color="#333333", penwidth=1.0, arrowsize=0.7];

  s2    [label="Sentinel-2 image collection (per year)"];
  mask  [label="Cloud mask (QA60) + median composite"];
  idx   [label="Spectral indices\nNDVI · NDWI · MNDWI · BSI"];
  stack [label="14-band feature stack\n(10 raw bands + 4 indices)", fillcolor="#e9e9e9"];

  ead   [label="EAD training polygons\n(seagrass / non-seagrass)", shape=note, fillcolor="#f2f2f2", color="#9a9a9a", fontsize=10, fontcolor="#444444"];
  samp  [label="Stratified training samples\n(80 / 20 train-test split)"];

  rf    [label="Random Forest\n(100 trees, seed = 42)", fillcolor="#e9e9e9"];
  cls   [label="Seagrass classification (2024)"];
  acc   [label="Accuracy assessment\n85.3%  ·  kappa 0.70", fillcolor="#2b2b2b", fontcolor="white", color="#2b2b2b"];

  s2 -> mask -> idx -> stack;
  ead -> samp;
  stack -> samp;
  samp -> rf -> cls -> acc;
}
