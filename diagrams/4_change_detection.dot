digraph change_detection {
  rankdir=LR;
  graph [fontname="Helvetica", label="Track B — Change Detection (2019 vs 2024)", labelloc=t, fontsize=15, fontcolor="#111111", bgcolor="white", nodesep=0.35, ranksep=0.6, pad=0.3];
  node  [shape=box, style="rounded,filled", fillcolor="white", color="#222222", penwidth=1.1, fontname="Helvetica", fontsize=11, fontcolor="#111111", margin="0.16,0.10"];
  edge  [color="#333333", penwidth=1.0, arrowsize=0.7];

  c19 [label="2019\nfeature stack"];
  c24 [label="2024\nfeature stack"];
  rf  [label="Same Random Forest\nclassifier", fillcolor="#e9e9e9"];
  m19 [label="2019\nseagrass map"];
  m24 [label="2024\nseagrass map"];
  diff [label="Pixel-by-pixel\ndifference"];

  subgraph cluster_out {
    label="  CHANGE CLASSES  "; labeljust=l; style="rounded"; color="#9a9a9a"; fontsize=10; fontcolor="#555555";
    k0 [label="Stable\nnon-seagrass"];
    k1 [label="Stable\nseagrass"];
    k2 [label="Gain"];
    k3 [label="Loss", fillcolor="#2b2b2b", fontcolor="white", color="#2b2b2b"];
  }

  c19 -> rf; c24 -> rf;
  rf -> m19; rf -> m24;
  m19 -> diff; m24 -> diff;
  diff -> k0; diff -> k1; diff -> k2; diff -> k3;

  loss_note [label="\"Loss\" is the most heavily\nweighted threat factor (0.30)", shape=plaintext, style="", fontsize=9, fontcolor="#555555"];
  k3 -> loss_note [style=dotted, arrowhead=none, color="#888888"];
}
